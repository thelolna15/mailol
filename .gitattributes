# Auto detect text files and normalize line endings (LF)
* text=auto

# Source code
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.html text eol=lf
*.mjs text eol=lf

# Config
*.env text eol=lf
.gitignore text eol=lf
.dockerignore text eol=lf
Dockerfile text eol=lf

# Binary — treat as binary, no diff
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary

# Lock files — show diff but don't merge conflicts
package-lock.json -diff
