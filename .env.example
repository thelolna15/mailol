# ================================================================
# MaiLoL — Environment Variables
# Copy this file to .env on your server before running docker compose
# ================================================================

# Node Configuration
NODE_ENV=development / production

# Domain Configuration
DOMAIN=thelol.me
NEXT_PUBLIC_DOMAIN=thelol.me

# Redis Connection
REDIS_URL=redis://redis:6379

# Authentication (CHANGE THIS! Generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_256_BIT_STRING
JWT_EXPIRY=3600

# Quota Controls (max inbox storage in bytes, default 40MB)
DEFAULT_QUOTA=41943040
